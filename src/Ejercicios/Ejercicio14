using System;
using Optativa.Shared;

namespace Optativa.Ejercicios
{
    public class Ejercicio14 : IExercise
    {
        public void Run()
        {
            Console.WriteLine("Calcular el valor de un numero Factorial");
            int n = IO.ReadInt("Número (>=0): ");
            if (n < 0) { Console.WriteLine("Debe ser no negativo."); return; }

            try
            {
                checked
                {
                    long f = 1;
                    for (int i = 2; i <= n; i++) f *= i;
                    Console.WriteLine(f);
                }
            }
            catch (OverflowException)
            {
                Console.WriteLine("Overflow: el resultado es demasiado grande para long.");
            }
        }
    }
}