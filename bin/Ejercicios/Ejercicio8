using System;
using Optativa.Shared;

namespace Optativa.Ejercicios
{
    public class Ejercicio8 : IExercise
    {
        public void Run()
        {
            Console.WriteLine("8) Suma de Pares (1..50)");
            int sum = 0; for (int i = 2; i <= 50; i += 2) sum += i;
            Console.WriteLine(sum);
        }
    }
