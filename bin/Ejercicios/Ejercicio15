using System;
using Optativa.Shared;

namespace Optativa.Ejercicios
{
    public class Ejercicio15 : IExercise
    {
        public void Run()
        {
            Console.WriteLine("15) Validador de Rango [10..20]");
            int n = IO.ReadInt("Número: ");
            Console.WriteLine(n >= 10 && n <= 20 ? "Está en el rango." : "Fuera del rango.");
        }
    }
}